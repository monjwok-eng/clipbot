// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: clips
// Document ID: 8-character alphanumeric code (e.g., "ABC123XY")
// Fields:
//   - content: string (required, max 10000 chars)
//   - createdAt: timestamp (required)
//   - expiresAt: timestamp (required)
//
// Collection: users
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - tier: string (required, enum: guest, pro, promax)
//   - onboardingSeen: boolean (optional)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.get('authorUid', '');
    }

    function isValidClip(data) {
      return data.keys().hasAll(['content', 'createdAt', 'expiresAt']) &&
             data.content is string && data.content.size() <= 100000 &&
             data.createdAt is timestamp &&
             data.expiresAt is timestamp &&
             (data.authorUid == null || data.authorUid is string);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'tier']) &&
             data.uid == request.auth.uid &&
             data.tier in ['guest', 'pro', 'promax'] &&
             (data.onboardingSeen == null || data.onboardingSeen is bool) &&
             (data.apiKey == null || data.apiKey is string);
    }

    function isValidFolder(data) {
      return data.keys().hasAll(['name', 'ownerUid', 'members', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.ownerUid is string &&
             data.members is list &&
             data.createdAt is timestamp;
    }

    match /bundles/{bundleId} {
      allow get: if isAuthenticated() && request.auth.uid == resource.data.get('ownerUid', '');
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.get('ownerUid', '');
    }

    match /clips/{code} {
      allow create: if code.matches("^[A-Z0-9-]{3,20}$") && 
                      isValidClip(request.resource.data);
      allow get: if true;
      allow update: if (isDocOwner() && isValidClip(request.resource.data)) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['expiresAt']) && 
                       request.resource.data.expiresAt == request.time) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']) &&
                       request.resource.data.viewCount is int &&
                       request.resource.data.viewCount == resource.data.get('viewCount', 0) + 1);
      allow delete: if isDocOwner(); // Only owner can delete
      allow list: if true; // Allows the authorized query
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /history/{clipId} {
        allow read, write: if isOwner(userId);
      }
      
      match /savedClips/{clipId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /folders/{folderId} {
      function isMember() {
        return isAuthenticated() && 
               resource.data.members is list && 
               request.auth.uid in resource.data.members;
      }
      
      allow read: if isMember();
      allow create: if isAuthenticated() && 
                      request.resource.data.ownerUid == request.auth.uid &&
                      request.resource.data.members is list &&
                      request.auth.uid in request.resource.data.members &&
                      isValidFolder(request.resource.data);
      allow update: if isMember() && 
                      request.resource.data.ownerUid == resource.data.ownerUid &&
                      isValidFolder(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;

      match /clips/{clipId} {
        allow read, write: if isMember();
      }
    }
  }
}
